# GoCardless / Nordigen Bank Account Data API
GOCARDLESS_SECRET_ID=your_secret_id_from_gocardless_dashboard
GOCARDLESS_SECRET_KEY=your_secret_key_from_gocardless_dashboard

# Telegram Bot
TELEGRAM_BOT_TOKEN=1234567890:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Optional overrides (defaults shown)
DATABASE_URL=sqlite:///./data/finance.db
SYNC_INTERVAL_HOURS=12
EXPENSE_ALERT_THRESHOLD=100.0
SALARY_MIN_AMOUNT=1500.0
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
