# ── GoCardless / Nordigen Bank Account Data API ───────────────────────────────
# Crea tu cuenta en https://bankaccountdata.gocardless.com
# Free tier: hasta 50 requisiciones (bancos) y 90 días de historial
GOCARDLESS_SECRET_ID=your_secret_id_from_gocardless_dashboard
GOCARDLESS_SECRET_KEY=your_secret_key_from_gocardless_dashboard

# ── Telegram Bot (opcional) ───────────────────────────────────────────────────
# Crea un bot con @BotFather en Telegram y pega el token aquí
TELEGRAM_BOT_TOKEN=1234567890:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Autenticación JWT ─────────────────────────────────────────────────────────
# SECRET_KEY: genera un string aleatorio largo, por ejemplo:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIA-ESTO-POR-UN-STRING-ALEATORIO-DE-64-CHARS

# Usuario de acceso a la app
APP_USERNAME=admin

# Hash bcrypt de tu contraseña. Para generarlo:
#   python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('tu_password'))"
APP_PASSWORD_HASH=$2b$12$reemplaza_este_hash_con_el_tuyo

# ── URLs ──────────────────────────────────────────────────────────────────────
# URL pública de tu backend (sin slash final). GoCardless redirige aquí tras el login bancario.
# En local: http://localhost:8000
# En producción: https://tu-dominio.com
PUBLIC_URL=http://localhost:8000

# Orígenes permitidos para CORS (separa con comas)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Base de datos ─────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/finance.db

# ── Comportamiento ────────────────────────────────────────────────────────────
SYNC_INTERVAL_HOURS=12
EXPENSE_ALERT_THRESHOLD=100.0
SALARY_MIN_AMOUNT=1500.0
